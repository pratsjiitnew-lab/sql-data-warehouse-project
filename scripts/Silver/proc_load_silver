
/*
Stored Procedure: Loading Silver layer tables

Script Purpose: 
This Stored procedure loads data data into the Silver layer schema from Bronze layer tables:
It first truncates the tables before loading and then uses diferent Data cleaning,Transformation, Normalization,
Standardization steps from Bronze layer tables
before loading into 

Parameters: None. This procedure doesnt accept or return any values. Run this script whenever user wants
to load fresh data into the silver layer tables for analysis

*/

CREATE OR ALTER PROCEDURE silver.load_silver AS
BEGIN
	DECLARE @start_time DATETIME, @end_time DATETIME, @batch_start_time DATETIME, @batch_end_time DATETIME;
	BEGIN TRY
		
		SET @batch_start_time = GETDATE();
		PRINT '=========================================';
		PRINT 'Loading Silver Layer';
		PRINT '=========================================';

		PRINT'-----------------------------------------';
		PRINT 'Loading CRM Tables';
		PRINT'-----------------------------------------';

		SET @start_time = GETDATE();
		-- Cleaning the data for any unwanted spaces,transforming some columns to readable format, Hnadling Missing values and inserting into silver layer table
		PRINT '>> Truncating the table silver.crm_cust_info';
		TRUNCATE TABLE silver.crm_cust_info;

		PRINT '>> Inserting the data in table silver.crm_cust_info';

		INSERT INTO silver.crm_cust_info( -- Inserting ehe cleaned data into the silver layer table

			cst_id,
			cst_key,
			cst_firstname,
			cst_lastname,
			cst_marital_status,
			cst_gender,
			cst_create_date)

		SELECT
		cst_id,
		cst_key,
		TRIM(cst_firstname) AS cst_first_name,
		TRIM(cst_lastname) AS cst_lastname,
		CASE WHEN UPPER(TRIM(cst_marital_status)) = 'S' THEN 'Single'
			 WHEN UPPER(TRIM(cst_marital_status)) = 'M' THEN 'Married'
			 ELSE 'n/a'
		END as cst_marital_status, -- Transforming the Marital status value to readable format
		CASE WHEN UPPER(TRIM(cst_gender)) = 'M' THEN 'Male'
			 WHEN UPPER(TRIM(cst_gender)) = 'F' THEN 'Female'
			 ELSE 'n/a'
		END as cst_gender, -- Transforming the Gender value to readable format and transforming Null values to n/a
		cst_create_date
		FROM 
		(
			SELECT
			*, ROW_NUMBER() OVER(PARTITION BY cst_id ORDER BY cst_create_date DESC) AS flag_last
			FROM bronze.crm_cust_info
			WHERE cst_id IS NOT NULL
	
		)t 
		WHERE flag_last =1; -- Selecting the most recent record for the duplicate cust_id's

		SET @end_time = GETDATE();
		PRINT '>> Load Duration:' + CAST(DATEDIFF(second, @start_time, @end_time) AS NVARCHAR) + ' seconds';
		PRINT '---------------------------';


		SET @start_time = GETDATE();

		PRINT '>> Truncating the table silver.crm_prd_info';
		TRUNCATE TABLE silver.crm_prd_info;

		PRINT '>> Inserting the data in table silver.crm_prd_info';

		INSERT INTO silver.crm_prd_info (
			prd_id, 
			cat_id,
			prd_key,
			prd_name,
			prd_cost,
			prd_line,
			prd_start_dt,
			prd_end_dt
		)
		SELECT
		prd_id,
		REPLACE(SUBSTRING(prd_key,1,5), '-', '_')AS cat_id, -- Extracting the category Id from the product key
		SUBSTRING(prd_key,7,LEN(prd_key)) as prd_key, -- Extracting the product key
		prd_name,
		ISNULL(prd_cost,0) AS prd_cost,
		CASE WHEN UPPER(TRIM(prd_line)) = 'M' THEN 'Mounting'
			 WHEN UPPER(TRIM(prd_line)) = 'R' THEN 'Road'
			 WHEN UPPER(TRIM(prd_line)) = 'S' THEN 'Other Sales'
			 WHEN UPPER(TRIM(prd_line)) = 'T' THEN 'Touring'
			 ELSE 'n/a'
		END as prd_line, -- Normalizing the product line data and removing spaces if any
		prd_start_dt,
		DATEADD(DAY, -1, LEAD(prd_start_dt) OVER (PARTITION BY prd_key ORDER BY prd_start_dt))
		  AS prd_end_dt -- Calculating the end date as one day before the next start date
		FROM bronze.crm_prd_info;

		SET @end_time = GETDATE();
		PRINT '>> Load Duration:' + CAST(DATEDIFF(second, @start_time, @end_time) AS NVARCHAR) + ' seconds';
		PRINT '---------------------------';

		SET @start_time = GETDATE();
		PRINT '>> Truncating the table silver.crm_sales_details';
		TRUNCATE TABLE silver.crm_sales_details;

		PRINT '>> Inserting the data in table silver.crm_sales_details';

		--Cleaning the data from bronze layer crm_sales_details, transforming it and storing it in silver layer crm_sales_details

		INSERT INTO silver.crm_sales_details (
			sls_ord_num,
			sls_prod_key,
			sls_cust_id,
			sls_order_dt,
			sls_ship_dt,
			sls_due_dt,
			sls_sales,
			sls_quantity,
			sls_price
		)

		SELECT 
		sls_ord_num ,
		sls_prod_key,
		sls_cust_id,
		CASE WHEN sls_order_dt = 0 OR LEN(sls_order_dt)!= 8 THEN NULL
			 ELSE CAST(CAST(sls_order_dt AS VARCHAR) AS DATE) -- Data correctness for sales order date and changing the datatype from Int to Varchar
		END AS sls_order_dt,
		CASE WHEN sls_ship_dt = 0 OR LEN(sls_ship_dt)!= 8 THEN NULL-- Data correctness for sales ship date and changing the datatype from Int to Varchar
			 ELSE CAST(CAST(sls_ship_dt AS VARCHAR) AS DATE)
		END AS sls_ship_dt,
		CASE WHEN sls_due_dt = 0 OR LEN(sls_due_dt)!= 8 THEN NULL -- Data correctness for sales due date and changing the datatype from Int to Varchar
			 ELSE CAST(CAST(sls_due_dt AS VARCHAR) AS DATE)
		END AS sls_due_dt,
		CASE 
			 WHEN sls_sales IS NULL OR sls_sales<=0 OR sls_sales != abs(sls_price)*sls_quantity  THEN ABS(sls_price) *sls_quantity 
			 ELSE sls_sales --- Handling Nulls, zeroes or negative values for sls_sales and making it consistent with price and quantity (Sales = price*quantity)
		END sls_sales,
		sls_quantity,
		CASE 
			 WHEN sls_price IS NULL OR sls_price<=0 THEN ABS(sls_sales)/NULLIF(sls_quantity,0)
			 ELSE sls_price --- Handling Nulls, zeroes or negative values for sls_price and making it consistent with sales and quantity (Price = sales/quantity)
		END sls_price

		FROM bronze.crm_sales_details;

		SET @end_time = GETDATE();
		PRINT '>> Load Duration:' + CAST(DATEDIFF(second, @start_time, @end_time) AS NVARCHAR) + ' seconds';
		PRINT '---------------------------';


		SET @start_time = GETDATE();
		PRINT '>> Truncating the table silver.erp_cust_az12';
		TRUNCATE TABLE silver.erp_cust_az12;

		PRINT '>> Inserting the data in table silver.erp_cust_az12';

		PRINT'-----------------------------------------';
		PRINT 'Loading ERP Tables';
		PRINT'-----------------------------------------';
		INSERT INTO silver.erp_cust_az12( -- Inserting the cleaned data into to silver layer erp_cust_az12 table

		cid,
		bdate,
		gen
		)

			SELECT
			CASE WHEN LEN(cid)=13 THEN SUBSTRING(cid,4,LEN(cid)) -- Extracting the cid to prepare the data to join it with the crm_cust_info table
				ELSE cid
			END as cid,
			CASE WHEN bdate > GETDATE() THEN NULL -- Filtering out the Bad data of the future birth date values
				ELSE bdate
				END as bdate,
			CASE WHEN UPPER(TRIM(gen)) IN ('F','FEMALE') THEN 'Female' -- Categorizing the Gender values to a standardized values and taking care of Nulls and zeroes
				 WHEN UPPER(TRIM(gen)) IN ('M','MALE') THEN 'Male'
				 ELSE 'n/a'
			END as gen
			FROM bronze.erp_cust_az12;

		SET @end_time = GETDATE();
		PRINT '>> Load Duration:' + CAST(DATEDIFF(second, @start_time, @end_time) AS NVARCHAR) + ' seconds';
		PRINT '---------------------------';


		SET @start_time = GETDATE();
		PRINT '>> Truncating the table silver.erp_loc_a101';
		TRUNCATE TABLE silver.erp_loc_a101;

		PRINT '>> Inserting the data in table silver.erp_loc_a101';



		INSERT INTO silver.erp_loc_a101(
		cid,
		cntry
		)

		SELECT 
		REPLACE(cid,'-','') as cid,-- removing the unwanted character in the primary key to be able to Join with other tables
		CASE 
			 WHEN SUBSTRING(UPPER(TRIM(cntry)),1,len(UPPER(TRIM(cntry)))-1) IN ('USA', 'UNITED STATES', 'US') THEN 'USA' -- Standardizing the cntry values and also removes spaces and hidden spaces
			 WHEN SUBSTRING(UPPER(TRIM(cntry)),1,len(UPPER(TRIM(cntry)))-1) IN ('GERMANY', 'DE') THEN 'Germany'
			 WHEN SUBSTRING(UPPER(TRIM(cntry)),1,len(UPPER(TRIM(cntry)))-1) IN ('FRANCE') THEN 'France'
			 WHEN SUBSTRING(UPPER(TRIM(cntry)),1,len(UPPER(TRIM(cntry)))-1) IN ('UNITED KINGDOM') THEN 'UK'
			 WHEN SUBSTRING(UPPER(TRIM(cntry)),1,len(UPPER(TRIM(cntry)))-1) IN ('AUSTRALIA') THEN 'Australia'
			 WHEN SUBSTRING(UPPER(TRIM(cntry)),1,len(UPPER(TRIM(cntry)))-1) IN ('CANADA') THEN 'Canada'
			 ELSE 'n/a'
		END AS cntry
		FROM bronze.erp_loc_a101;

		SET @end_time = GETDATE();
		PRINT '>> Load Duration:' + CAST(DATEDIFF(second, @start_time, @end_time) AS NVARCHAR) + ' seconds';
		PRINT '---------------------------';


		SET @start_time = GETDATE();
		PRINT '>> Truncating the table silver.erp_px_cat_g1v2';
		TRUNCATE TABLE silver.erp_px_cat_g1v2;

		PRINT '>> Inserting the data in table silver.erp_px_cat_g1v2';


		INSERT INTO silver.erp_px_cat_g1v2(
		id,
		cat,
		subcat,
		maintenance
		)

			SELECT 
			id,
			cat,
			subcat,
			maintenance
			FROM bronze.erp_px_cat_g1v2;

		SET @end_time = GETDATE();
		PRINT '>> Load Duration:' + CAST(DATEDIFF(second, @start_time, @end_time) AS NVARCHAR) + ' seconds';
		PRINT '---------------------------';

		SET @batch_end_time = GETDATE();
		PRINT'Loading Silver layer is completed-';
		PRINT '>> Total Load Duration:' + CAST(DATEDIFF(second, @batch_start_time, @batch_end_time) AS NVARCHAR) + ' seconds';
		PRINT '---------------------------';

	END TRY
	BEGIN CATCH
			PRINT'Error happened during the Silver layer. Please check your Code and analyze code correctly';
			PRINT'Error Message' + ERROR_MESSAGE();
			PRINT'Error Message' + CAST(ERROR_NUMBER() AS NVARCHAR);
			PRINT'Error Message' + CAST(ERROR_STATE() AS NVARCHAR);

	END CATCH

END





