-- To check product key is unique

SELECT prd_key, COUNT(*) FROM

(
	SELECT 
		pif.prd_id,
		pif.cat_id,
		pif.prd_key,
		pif.prd_name,
		pif.prd_cost,
		pif.prd_line,
		pif.prd_start_dt,
		pif.prd_end_dt,
		pdf.cat,
		pdf.maintenance,
		pdf.subcat

		FROM silver.crm_prd_info pif
		LEFT JOIN silver.erp_px_cat_g1v2 pdf
		ON pif.cat_id = pdf.id

	WHERE pif.prd_end_dt IS NULL -- Filtering out all historical data
)t

GROUP BY prd_key
HAVING Count(*) >1
